# Supabase (obligatoire en production)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Production — URL du site (sitemap, robots, métadonnées). Ex: https://ton-site.vercel.app
NEXT_PUBLIC_SITE_URL=

# Optionnel — Génération de lettres (Documents)
ANTHROPIC_API_KEY=

# Optionnel — Notifications email
RESEND_API_KEY=
ADMIN_EMAIL=

# Ne pas committer .env.local ni les secrets (voir .gitignore)
